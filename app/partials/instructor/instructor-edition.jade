//- Sergio Utrilla added - Instructor Dashboard: vista de detalle de una edition con equipos y métricas agregadas
div.wrapper
    section.main.instructor-edition
        div.error-message(ng-if="view.error && !view.loading")
            div.alert.alert-error
                p(translate="{{ view.error }}")

        div.edition-dashboard(ng-if="!view.loading && !view.error")
            header.edition-header
                div.header-left
                    h1.edition-key {{ view.edition.key }}
                    //- Coordinator/Professor view toggle (shown only when user is both)
                    div.view-mode-toggle(ng-if="view.showViewToggle")
                        button.view-mode-btn(
                            ng-class="{'active': view.professorView}"
                            ng-click="switchToProfessorView()"
                            translate="INSTRUCTOR.VIEW_AS_PROFESSOR"
                        )
                        button.view-mode-btn(
                            ng-class="{'active': !view.professorView}"
                            ng-click="switchToCoordinatorView()"
                            translate="INSTRUCTOR.VIEW_AS_COORDINATOR"
                        )
                div.header-actions
                    a.btn-small(
                        ng-if="view.canEditSettings"
                        tg-nav="instructor-edition-settings:editionKey=view.edition.key"
                        variant="secondary"
                    )
                        span(translate="INSTRUCTOR.SETTINGS_LINK")
                    button.btn-small(
                        variant="secondary"
                        ng-click="refresh()"
                        ng-disabled="view.refreshing"
                    )
                        span(ng-if="!view.refreshing" translate="INSTRUCTOR.REFRESH")
                        span(ng-if="view.refreshing" translate="INSTRUCTOR.REFRESHING")

            //- Team cards
            div.no-groups(ng-if="view.groups.length === 0")
                div.empty-state
                    p(translate="INSTRUCTOR.NO_TEAMS")

            div.groups-grid(ng-if="view.groups.length > 0")
                div.group-card(
                    ng-repeat="group in view.groups track by group.group_id"
                    tg-nav="instructor-group:editionKey=view.edition.key,groupCode=group.group_code"
                    style="cursor:pointer;"
                )
                    div.group-card-header
                        h3.group-code {{ group.group_code }}
                        span.group-name {{ group.display_name }}

                    div.group-project(ng-if="group.project_slug")
                        a.project-link(href="/project/{{ group.project_slug }}/metrics/project")
                            span {{ group.project_name }}

                    div.group-snapshot-date
                        span(translate="INSTRUCTOR.SNAPSHOT_AT")
                        span &nbsp;{{ group.snapshot_computed_at | date:'dd/MM/yyyy HH:mm' }}

                    div.group-new-project(ng-if="group.is_new_project")
                        p(translate="INSTRUCTOR.GROUP_NEW_PROJECT")

                    div.group-metrics-gauges(ng-if="!group.is_new_project && group.metrics.length > 0")
                        div.metric-gauge-item(
                            ng-repeat="metric in group.metrics track by metric.id"
                            ng-if="metric.classification === 'project'"
                        )
                            tg-speedometer-chart(
                                value="metric.value"
                                raw-value="metric.value"
                                max-value="1"
                                label="{{ metric.name }}"
                                metric-key="{{ metric.id }}"
                                color="metric.color"
                                palette="metric.palette"
                            )
                            span.gauge-label {{ metric.name }}

            //- Aggregated comparison: shown when more than 1 team
            div.aggregated-section(ng-if="view.groups.length > 1")
                div.aggregated-header
                    h2(translate="INSTRUCTOR.AGGREGATED_TITLE")
                    //- Team filter
                    div.comparison-filter
                        span.comparison-filter-label(translate="INSTRUCTOR.COMPARISON_FILTER_TITLE")
                        div.comparison-filter-chips
                            button.comparison-chip(
                                ng-repeat="group in view.groups track by group.group_id"
                                ng-class="{'active': isGroupInComparison(group.group_id)}"
                                ng-click="toggleGroupInComparison(group.group_id)"
                            ) {{ group.group_code }}
                        span.comparison-count {{ getSelectedGroupCount() }}/{{ view.groups.length }} teams selected
                    //- Metric filter
                    div.comparison-filter(ng-if="view.allChartsList.length > 1")
                        span.comparison-filter-label(translate="INSTRUCTOR.COMPARISON_METRIC_FILTER_TITLE")
                        div.comparison-filter-chips
                            button.comparison-chip(
                                ng-repeat="item in view.allChartsList track by item.metric_id"
                                ng-class="{'active': isMetricInComparison(item.metric_id)}"
                                ng-click="toggleMetricInComparison(item.metric_id)"
                            ) {{ item.metric_name }}
                        span.comparison-count {{ getSelectedMetricCount() }}/{{ view.allChartsList.length }} metrics selected

                div.aggregated-charts-grid
                    div.aggregated-chart-card(ng-repeat="item in view.filteredChartsList track by item.metric_id + '_' + view.chartVersion")
                        h4.agg-metric-name {{ item.metric_name }}
                        div.agg-stats-row
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.AVG")
                                span.stat-value &nbsp;{{ item.avg | number:2 }}%
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.MIN")
                                span.stat-value &nbsp;{{ item.min | number:2 }}%
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.MAX")
                                span.stat-value &nbsp;{{ item.max | number:2 }}%
                        tg-bar-chart(data="item.chartData")
