//- Sergio Utrilla added - Instructor Dashboard: vista de detalle de una edition con grupos y métricas agregadas
div.wrapper
    section.main.instructor-edition
        div.error-message(ng-if="view.error && !view.loading")
            div.alert.alert-error
                p(translate="{{ view.error }}")

        div.edition-dashboard(ng-if="!view.loading && !view.error")
            header.edition-header
                div.header-left
                    h1.edition-key {{ view.edition.key }}
                div.header-actions
                    a.button.small(tg-nav="instructor-edition-settings:editionId=view.edition.id")
                        span(translate="INSTRUCTOR.SETTINGS_LINK")
                    button.button.small(
                        ng-click="refresh()"
                        ng-disabled="view.refreshing"
                    )
                        span(ng-if="!view.refreshing" translate="INSTRUCTOR.REFRESH")
                        span(ng-if="view.refreshing" translate="INSTRUCTOR.REFRESHING")

            //- Aggregated charts: one bar chart per metric comparing all groups
            div.aggregated-section(ng-if="view.groups.length > 1")
                h2(translate="INSTRUCTOR.AGGREGATED_TITLE")
                div.aggregated-charts-grid
                    div.aggregated-chart-card(ng-repeat="(metricId, data) in view.aggregated track by metricId")
                        h4.agg-metric-name {{ data.metric_name }}
                        div.agg-stats-row
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.AVG")
                                span.stat-value &nbsp;{{ data.avg | number:2 }}
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.MIN")
                                span.stat-value &nbsp;{{ data.min | number:2 }}
                            span.agg-stat
                                span.stat-label(translate="INSTRUCTOR.MAX")
                                span.stat-value &nbsp;{{ data.max | number:2 }}
                        tg-bar-chart(data="view.charts[metricId]")

            //- Group cards
            div.no-groups(ng-if="view.groups.length === 0")
                div.empty-state
                    p(translate="INSTRUCTOR.NO_GROUPS")

            div.groups-grid(ng-if="view.groups.length > 0")
                div.group-card(
                    ng-repeat="group in view.groups track by group.group_id"
                    tg-nav="instructor-group:editionId=view.edition.id,groupId=group.group_id"
                    style="cursor:pointer;"
                )
                    div.group-card-header
                        h3.group-code {{ group.group_code }}
                        span.group-name {{ group.display_name }}

                    div.group-project(ng-if="group.project_slug")
                        a.project-link(href="/project/{{ group.project_slug }}/metrics/project")
                            span {{ group.project_name }}

                    div.group-snapshot-date
                        span(translate="INSTRUCTOR.SNAPSHOT_AT")
                        span &nbsp;{{ group.snapshot_computed_at | date:'dd/MM/yyyy HH:mm' }}

                    div.group-new-project(ng-if="group.is_new_project")
                        p(translate="INSTRUCTOR.GROUP_NEW_PROJECT")

                    div.group-metrics-gauges(ng-if="!group.is_new_project && group.metrics.length > 0")
                        div.metric-gauge-item(
                            ng-repeat="metric in group.metrics track by metric.id"
                            ng-if="metric.classification === 'project'"
                        )
                            tg-speedometer-chart(
                                value="metric.value"
                                raw-value="metric.value"
                                max-value="1"
                                label="{{ metric.name }}"
                                metric-key="{{ metric.id }}"
                            )
                            span.gauge-label {{ metric.name }}
