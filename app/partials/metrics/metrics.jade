doctype html

div.wrapper
    tg-project-menu
    section.main.metrics
        header.metrics-header
            h1
                span(translate="METRICS.SECTION_NAME")
        
        section.metrics-content
            //- Testing view (accessible without authentication)
            div.testing-view(ng-if="metricsView.showTesting")
                div.testing-header
                    h2 TESTING - Mock Charts (Based on AMEP11ChopChop)
                    button.button(ng-click="hideTestingView()") Volver
                
                //- Explanation/Guide section
                div.testing-guide
                    
                    div.guide-section
                        h4 🎨 Librería utilizada: Chart.js
                        p.code-example Referencia: <code>app/coffee/modules/metrics/charts.coffee</code>
                    
                div.testing-charts
                    div.chart-container
                        h3 Development Metrics
                        p.chart-subtitle 4 metrics: Tasks SD (7%), Commits SD (19%), Closed Tasks (83%), Modified Lines (0%)
                        canvas#radarChart(width="400", height="400")
                    div.chart-container
                        h3 Overall Quality Score
                        p.chart-subtitle Average of strategic indicators (11%)
                        canvas#semicircleChart(width="400", height="300")

        //- Metrics dashboard
        div.metrics-dashboard(ng-if="!metricsView.showTesting")

            div.loading-container(ng-if="metricsView.loading")
                div.spinner
                p(translate="METRICS.LOADING")

                div.error-message(ng-if="metricsView.error && !metricsView.loading")
                    div.alert.alert-error
                        i.icon.icon-error
                        p(translate="{{ metricsView.error }}")
                        button.button.small(ng-click="reloadMetrics()", translate="METRICS.RETRY")

                div.error-message(ng-if="metricsView.isNewProject && !metricsView.loading")
                    div.alert.alert-warning
                        i.icon.icon-warning
                        p(translate="METRICS.PROJECT_NOT_IN_SYSTEM")
                        p.small-text(translate="METRICS.PROJECT_NOT_IN_SYSTEM_HINT")

                div.metrics-body(ng-if="metricsView.data && !metricsView.loading && !metricsView.isNewProject")
                    div.metrics-tabs
                        button.tab-button(
                            ng-repeat="tab in availableTabs"
                            ng-class="{'active': metricsView.activeTab === tab.id}"
                            ng-click="setActiveTab(tab.id)"
                        )
                            span(translate="{{ tab.label }}")

                    div.error-message(ng-if="metricsView.errors && Object.keys(metricsView.errors).length > 0")
                        div.alert.alert-warning
                            i.icon.icon-warning
                            div
                                p(translate="METRICS.PARTIAL_DATA_WARNING")
                                ul
                                    li(ng-repeat="(section, detail) in metricsView.errors")
                                        span.section {{ section }}:
                                        span.detail(ng-if="detail.detail && detail.detail.error") {{ detail.detail.error }}
                                        span.detail(ng-if="!(detail.detail && detail.detail.error) && detail.error") {{ detail.error }}
                                        span.detail(ng-if="!(detail.detail && detail.detail.error) && !detail.error") {{ detail | json }}

                    div.metrics-content-panel(ng-switch="metricsView.activeTab")
                        //- Project metrics tab
                        div(ng-switch-when="project")
                            h2.section-title(translate="METRICS.PROJECT_METRICS_TITLE")

                            div.project-subtabs
                                button.project-subtab(type="button", ng-class="{'active': metricsView.projectSubTab === 'overview'}", ng-click="setProjectSubTab('overview')")
                                    span(translate="METRICS.PROJECT_TABS.OVERVIEW")
                                button.project-subtab(type="button", ng-class="{'active': metricsView.projectSubTab === 'historical'}", ng-click="setProjectSubTab('historical')")
                                    span(translate="METRICS.PROJECT_TABS.HISTORICAL")

                            div.project-tab-panels(ng-switch="metricsView.projectSubTab")
                                div.project-overview-panel(ng-switch-when="overview")
                            div.project-metrics-grid(ng-if="metricsView.data.projectMetrics && metricsView.data.projectMetrics.length > 0")
                                div.project-metric-card(ng-repeat="metric in metricsView.data.projectMetrics track by metric.id")
                                    div.project-metric-header
                                        h3.metric-name {{ metric.name }}
                                    div.project-metric-gauge
                                        div.project-metric-body
                                            div.project-metric-chart
                                                tg-speedometer-chart(
                                                    value="metric.ratioValue || (metric.absoluteValue / 100)"
                                                    raw-value="metric.ratioValue || (metric.absoluteValue / 100)"
                                                    max-value="1"
                                                    label="{{ metric.name }}"
                                                    metric-id="{{ metric.id }}"
                                                    color="metric.categoryColor"
                                                    palette="metric.categoryPalette"
                                                )
                                            div.project-metric-insights
                                                div.metric-value-wrapper
                                                    span.metric-value {{ metric.ratioDisplayValuePrecise || metric.ratioValue }}
                                                p.metric-description(ng-if="metric.description") {{ metric.description }}

                            div.no-data(ng-if="!metricsView.data.projectMetrics || metricsView.data.projectMetrics.length === 0")
                                div.empty-state
                                    i.icon.icon-info
                                            p(translate="METRICS.NO_DATA")

                                div.project-historical-panel(ng-switch-when="historical")
                                    div.project-historical-header
                                        h3(translate="METRICS.PROJECT_HISTORICAL_TITLE")
                                        p.description(translate="METRICS.PROJECT_HISTORICAL_DESCRIPTION")

                                    div.project-historical-filters.team-historical-filters
                                        div.filter-group.date-group
                                            label.filter-label(for="projectHistoricalDateFrom", translate="METRICS.PROJECT_HISTORICAL_DATE_FROM")
                                            input#projectHistoricalDateFrom(type="date", ng-model="metricsView.projectHistoricalFilters.dateFrom")
                                        div.filter-group.date-group
                                            label.filter-label(for="projectHistoricalDateTo", translate="METRICS.PROJECT_HISTORICAL_DATE_TO")
                                            input#projectHistoricalDateTo(type="date", ng-model="metricsView.projectHistoricalFilters.dateTo")
                                        div.filter-group.filter-actions
                                            button.filter-action(type="button", ng-click="clearProjectHistoricalDates()", ng-disabled="!metricsView.projectHistoricalFilters.dateFrom && !metricsView.projectHistoricalFilters.dateTo", translate="METRICS.PROJECT_HISTORICAL_CLEAR_DATES")

                                    div.project-historical-grid(ng-if="metricsView.projectHistoricalCharts.length > 0")
                                        div.project-historical-card(ng-repeat="chart in metricsView.projectHistoricalCharts track by chart.id")
                                            h4.chart-title {{ chart.title }}
                                            tg-area-chart(data="chart.chartData")

                                    div.project-historical-empty(ng-if="metricsView.projectHistoricalCharts.length === 0")
                                        div.empty-state
                                            i.icon.icon-info
                                            p(translate="METRICS.PROJECT_HISTORICAL_NO_DATA")

                        //- Team metrics tab (categories, hours, last report)
                        div(ng-switch-when="team")
                            h2.section-title(translate="METRICS.TEAM_METRICS_TITLE")

                            div.team-subtabs
                                button.team-subtab(type="button", ng-class="{'active': metricsView.teamSubTab === 'overview'}", ng-click="setTeamSubTab('overview')")
                                    span(translate="METRICS.TEAM_TABS.OVERVIEW")
                                button.team-subtab(type="button", ng-class="{'active': metricsView.teamSubTab === 'historical'}", ng-click="setTeamSubTab('historical')")
                                    span(translate="METRICS.TEAM_TABS.HISTORICAL")

                            div.team-tab-panels(ng-switch="metricsView.teamSubTab")
                                div.team-overview-panel(ng-switch-when="overview")
                                    
                                    //- Students Overall Radar Chart and Closed Tasks comparison
                                    div.team-section(ng-if="metricsView.data.studentsOverallRadar || metricsView.data.studentsClosedTasksBar")
                                        h3(translate="METRICS.STUDENTS_OVERALL")
                                        div.team-user-filter(ng-if="metricsView.teamOverview.uiUsers.length > 0")
                                            div.filter-header
                                                div.filter-info
                                                    span.filter-title(translate="METRICS.TEAM_USER_FILTER_TITLE")
                                                    span.filter-count {{ metricsView.teamOverview.activeCount }} / {{ metricsView.teamOverview.uiUsers.length }}
                                                button.team-user-reset(type="button", ng-click="resetTeamOverviewUsers()", ng-disabled="metricsView.teamOverview.activeCount === metricsView.teamOverview.uiUsers.length")
                                                    span(translate="METRICS.TEAM_USER_FILTER_RESET")
                                            div.filter-chips
                                                button.team-user-chip(type="button", ng-repeat="user in metricsView.teamOverview.uiUsers track by user.username", ng-click="toggleTeamOverviewUser(user.username)", ng-class="{'inactive': !metricsView.teamOverview.activeUsers[user.username]}")
                                                    span.user-color(style="background-color: {{ user.color }}; border-color: {{ user.borderColor }};")
                                                    span {{ user.displayName }}
                                        div.team-comparison-grid
                                            div.team-chart-container(ng-if="metricsView.teamOverview.filteredRadar && metricsView.teamOverview.filteredRadar.datasets.length > 0")
                                                h4.chart-title(translate="METRICS.TEAM_RADAR_BREAKDOWN")
                                                tg-radar-chart(data="metricsView.teamOverview.filteredRadar")
                                            div.team-chart-container(ng-if="metricsView.teamOverview.filteredClosedTasks && metricsView.teamOverview.filteredClosedTasks.labels && metricsView.teamOverview.filteredClosedTasks.labels.length > 0")
                                                h4.chart-title(translate="METRICS.CLOSED_TASKS_COMPARISON_TITLE")
                                                tg-bar-chart(data="metricsView.teamOverview.filteredClosedTasks")

                                    div.team-section(ng-if="metricsView.data.metricsCategories && Object.keys(metricsView.data.metricsCategories).length > 0")
                                        h3(translate="METRICS.METRICS_CATEGORIES")
                                        ul.key-value-list
                                            li(ng-repeat="(category, value) in metricsView.data.metricsCategories")
                                                span.key {{ category }}
                                                span.value {{ value | json }}

                                    div.team-section(ng-if="metricsView.data.hours && Object.keys(metricsView.data.hours).length > 0")
                                            h3(translate="METRICS.STUDENT_HOURS")
                                            tg-pie-chart(data="metricsView.data.hoursChart")

                                    div.team-section(ng-if="metricsView.data.lastReport && metricsView.data.lastReport.lastEvaluation")
                                        h3(translate="METRICS.LAST_EVALUATION_TITLE")
                                        p
                                            span(translate="METRICS.LAST_EVALUATION_AT", translate-values="{date: (metricsView.data.lastReport.lastEvaluation | tgLocalizedDate:'medium')}")
                                        div.last-report
                                            pre {{ metricsView.data.lastReport.report || (metricsView.data.lastReport | json) }}

                                    div.no-data(ng-if="(!metricsView.data.metricsCategories || Object.keys(metricsView.data.metricsCategories).length === 0) && (!metricsView.data.hours || Object.keys(metricsView.data.hours).length === 0) && (!metricsView.data.lastReport || !metricsView.data.lastReport.lastEvaluation)")
                                        div.empty-state
                                            i.icon.icon-info
                                            p(translate="METRICS.NO_DATA")

                                div.team-historical-panel(ng-switch-when="historical")
                                    div.team-historical-header
                                        h3(translate="METRICS.TEAM_HISTORICAL_TITLE")
                                        p.description(translate="METRICS.TEAM_HISTORICAL_DESCRIPTION")

                                    div.team-historical-grid(ng-if="metricsView.teamHistoricalCharts.length > 0")
                                        div.team-historical-card(ng-repeat="historicalChart in metricsView.teamHistoricalCharts track by historicalChart.id")
                                            h4.chart-title {{ (historicalChart.metricLabel | translate) || historicalChart.metricLabel || historicalChart.title }}
                                            span.chart-subtitle {{ historicalChart.user }}
                                            tg-area-chart(data="historicalChart.chartData")

                                    div.team-historical-empty(ng-if="metricsView.teamHistoricalCharts.length === 0")
                                        div.empty-state
                                            i.icon.icon-info
                                            p(translate="METRICS.TEAM_HISTORICAL_NO_DATA")
